        "backgroundColor": "#1a1a2e"
      },
      "package": "com.batterywebhook.app"
    },
    "extra": {
      "eas": {
        "projectId": "28900571-071f-4aef-b28f-a6d365154eb2"
      }
    },
    "owner": "lucon2806",
